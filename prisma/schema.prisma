// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum ReportStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ReportCategory {
  ROAD_ISSUE
  GRAFFITI
  ILLEGAL_DUMPING
  STREET_LIGHT_ISSUE
  OTHER
}

model User {
  id        String  @id @default(uuid())
  email     String  @unique
  password  String
  name      String?
  lastname  String?

  role       Role    @default(USER)

  isActive   Boolean @default(true)
  verified   Boolean @default(false)
  verifiedAt DateTime?
  verificationToken String? @unique

  resetToken           String? @unique
  resetPasswordExpires DateTime?

  isBanned   Boolean @default(false)
  bannedAt   DateTime?
  banReason  String?

  canReport  Boolean @default(false)
  isDeleted  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reports              Report[]
  reportStatusChanges  ReportStatusHistory[]
}

model Report {
  id          String @id @default(uuid())
  title       String
  description String
  category    ReportCategory @default(OTHER)

  latitude  Float
  longitude Float

  status     ReportStatus @default(PENDING)
  isVisible  Boolean      @default(true)
  isDeleted  Boolean      @default(false)

  userId  String
  user    User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  history ReportStatusHistory[]

  @@index([latitude, longitude])
  @@index([status])
  @@index([category])
}

model ReportStatusHistory {
  id            String @id @default(uuid())

  reportId      String
  report        Report @relation(fields: [reportId], references: [id])

  oldStatus     ReportStatus
  newStatus     ReportStatus

  changedById   String
  changedBy     User @relation(fields: [changedById], references: [id])

  changedAt     DateTime @default(now())
}

// ============================================
// Servicios de Tramites - dentro de este modelo se almacenan los datos comunes a todos los tipos de tramites, como el tipo de tramite, estado, fechas, etc. Los datos específicos de cada tipo de tramite se almacenan en la tabla ApplicationData como JSON para mantener flexibilidad. Las tablas Document y ApplicationHistory permiten gestionar los documentos adjuntos y el historial de cambios de estado respectivamente.
// ============================================

model Application {
  id               Int                @id @default(autoincrement())
  folio            String             @unique
  applicationType  ApplicationType
  status           ApplicationStatus  @default(DRAFT)

  personType       PersonType?

  requestDate      DateTime           @default(now())
  resolutionDate   DateTime?

  rejectionReason  String?

  userId           Int
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  user             User               @relation(fields: [userId], references: [id])
  data             ApplicationData?
  documents        Document[]
  history          ApplicationHistory[]

  @@index([applicationType])
  @@index([status])
}

// ============================================
// Datos específicos de cada tipo de tramite se almacenan en formato JSON para mantener flexibilidad y permitir la evolución de los requisitos sin necesidad de modificar la estructura de la base de datos. Cada registro en ApplicationData está vinculado a una única Application, y contiene un campo 'data' que puede almacenar cualquier información relevante para ese tipo de tramite, como detalles del evento, información de la empresa, datos personales, etc.
// ============================================

model ApplicationData {
  id            Int       @id @default(autoincrement())
  applicationId Int       @unique
  data          Json
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

// ============================================
// Documentos adjuntos a cada tramite. Cada documento está vinculado a un único tramite y contiene información sobre el tipo de documento, nombre del archivo, ruta de almacenamiento, tipo MIME, tamaño del archivo, y un indicador de si ha sido validado o no. Esto permite gestionar eficientemente los documentos relacionados con cada tramite y mantener un registro claro de los mismos.
// ============================================

model Document {
  id            Int      @id @default(autoincrement())
  applicationId Int

  documentType  String
  fileName      String
  filePath      String
  mimeType      String
  fileSize      Int

  validated     Boolean  @default(false)

  uploadedAt    DateTime @default(now())

  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}

// ============================================
// Historiual de tramites. Cada vez que un tramite cambia de estado, se crea un nuevo registro en esta tabla que almacena el ID del tramite, el estado anterior, el nuevo estado, la acción realizada (por ejemplo, "submit", "approve", "reject"), el ID del usuario que realizó la acción (si aplica), y la fecha y hora del cambio. Esto permite mantener un historial completo de los cambios de estado de cada tramite, facilitando la auditoría y el seguimiento de los mismos a lo largo del tiempo.
// ============================================

model ApplicationHistory {
  id             Int                 @id @default(autoincrement())
  applicationId  Int
  previousStatus ApplicationStatus?
  newStatus      ApplicationStatus
  action         String
  userId         Int?
  createdAt      DateTime            @default(now())

  application    Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}

enum ApplicationType {
  EVENTS
  PYROTECHNICS
  BUSINESS_REGISTRATION
  RESIDENCY
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  APPROVED
  REJECTED
}

enum PersonType {
  INDIVIDUAL
  LEGAL_ENTITY
}